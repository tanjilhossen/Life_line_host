# Node.js Server Port (Default is 3000)
PORT=3000

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD="your_db_password"
DB_NAME=lifeline_db

# Super Admin dashboard verification key (Master Admin password)
SUPER_ADMIN_KEY="your_super_admin_key"

# WhatsApp service toggle (true or false)
ENABLE_WHATSAPP=false
